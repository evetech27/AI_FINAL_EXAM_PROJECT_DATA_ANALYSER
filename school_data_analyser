import json

# The Dataset
school_stats = {
    "Programming for AI": {"Grade": 85, "Attendance": 95},
    "Cybersecurity": {"Grade": 78, "Attendance": 80},
    "Network Recon": {"Grade": 92, "Attendance": 98},
    "Data Ethics": {"Grade": 74, "Attendance": 70},
    "Web Security": {"Grade": 88, "Attendance": 90}
}

# --- FILE HANDLING ---
def save_data(data, filename="school_data.json"):
    with open(filename, "w") as f:
        json.dump(data, f, indent=4)
    print(f"Successfully saved data to {filename}")

def load_data(filename="school_data.json"):
    try:
        with open(filename, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        print("No existing data file found.")
        return None

# --- ANALYSIS LOGIC ---
def analyze_risk(data):
    print("\n--- AI Risk Analysis Report ---")
    for subject, metrics in data.items():
        # Logic: Flag if attendance < 75% or Grade < 75%
        if metrics["Attendance"] < 75 or metrics["Grade"] < 75:
            status = "⚠️ AT RISK"
        else:
            status = "✅ STABLE"
        
        print(f"{subject}: {status} (Att: {metrics['Attendance']}%, Grade: {metrics['Grade']}%)")

# Execute the workflow
save_data(school_stats)
loaded_stats = load_data()
analyze_risk(loaded_stats)