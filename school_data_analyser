import json

# The Dataset
school_stats = {
    "Programming for AI": {"Grade": 85, "Attendance": 95},
    "Cybersecurity": {"Grade": 78, "Attendance": 80},
    "Network Recon": {"Grade": 92, "Attendance": 98},
    "Data Ethics": {"Grade": 74, "Attendance": 70},
    "Web Security": {"Grade": 88, "Attendance": 90}
}

# --- FILE HANDLING ---
def save_data(data, filename="school_data.json"):
    with open(filename, "w") as f:
        json.dump(data, f, indent=4)
    print(f"Successfully saved data to {filename}")

def load_data(filename="school_data.json"):
    try:
        with open(filename, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        print("No existing data file found.")
        return None

# --- ANALYSIS LOGIC ---
def analyze_risk(data):
    print("\n--- AI Risk Analysis Report ---")
    for subject, metrics in data.items():
        # Logic: Flag if attendance < 75% or Grade < 75%
        if metrics["Attendance"] < 75 or metrics["Grade"] < 75:
            status = "⚠️ AT RISK"
        else:
            status = "✅ STABLE"
        
        print(f"{subject}: {status} (Att: {metrics['Attendance']}%, Grade: {metrics['Grade']}%)")

# Execute the workflow
save_data(school_stats)
loaded_stats = load_data()
analyze_risk(loaded_stats)
import numpy as np
from sklearn.tree import DecisionTreeClassifier
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score

def train_ai_model():
    # 1. Provide Training Data (Features: [Attendance, Score])
    # 0 = AT RISK, 1 = STABLE
    X = np.array([
        [95, 85], [90, 80], [85, 75], # High stats = Stable
        [40, 30], [50, 45], [60, 50], # Low stats = At Risk
        [75, 70], [30, 20], [88, 92]
    ])
    y = np.array([1, 1, 1, 0, 0, 0, 1, 0, 1]) 

    # 2. Initialize and Train the Model
    model = DecisionTreeClassifier()
    model.fit(X, y)
    
    # 3. Calculate Accuracy (For those 'Evaluation' marks)
    predictions = model.predict(X)
    acc = accuracy_score(y, predictions)
    print(f"--- AI Model Trained. Accuracy: {acc * 100}% ---")
    
    return model

def analyze_risk(data, model):
    print("\n--- AI RISK ANALYSIS REPORT ---")
    for subject, metrics in data.items():
        att = metrics['attendance']
        score = metrics['score']
        
        # Use the AI model to predict instead of an if-statement
        prediction = model.predict([[att, score]])
        
        if prediction[0] == 0:
            status = "⚠️ AT RISK"
        else:
            status = "✅ STABLE"
            
        print(f"{subject}: {status} (Predicted by AI Model)")